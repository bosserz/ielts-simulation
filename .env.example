FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL (Neon serverless recommended)
DATABASE_URL=postgresql://user:password@host/dbname

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=ielts-media
R2_PUBLIC_URL=https://your-bucket.r2.dev

# GCP Cloud Speech-to-Text (for speaking exam transcription)
# Paste the entire service account JSON as a single line.
# To convert: cat key.json | python3 -c "import json,sys; print(json.dumps(json.load(sys.stdin)))"
GCP_SERVICE_ACCOUNT_JSON=

# Sentry (optional, for error tracking)
SENTRY_DSN=
